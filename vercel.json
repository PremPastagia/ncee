{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/vite"
    }
  ],
  "routes": [
    {
      "src": "/api/egg-prices-history",
      "dest": "/api/egg-prices-history.py"
    },
    {
      "src": "/api/forecast-sarima",
      "dest": "/api/forecast-sarima.py"
    },
    {
      "src": "/api/egg-prices",
      "dest": "/api/egg-prices.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
